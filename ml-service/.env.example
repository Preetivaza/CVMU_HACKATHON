# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/road_damage_db
DATABASE_NAME=road_damage_db

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# DBSCAN Clustering Configuration
DBSCAN_EPS_METERS=10.0
DBSCAN_MIN_SAMPLES=3

# Risk Calculation Weights
RISK_WEIGHT_SEVERITY_NORMAL=0.7
RISK_WEIGHT_AGING_NORMAL=0.3
RISK_WEIGHT_SEVERITY_REPEAT=0.6
RISK_WEIGHT_AGING_REPEAT=0.4
REPEAT_THRESHOLD=3

# Google Earth Engine (leave empty if not configured)
GEE_SERVICE_ACCOUNT=
